{
  "manifest_version": 2,
  "name": "Container Tab Manager",
  "version": "1.0.0",
  "description": "Isolate every new tab in its own container by default, with smart URL-based sharing rules",
  "permissions": [
    "contextualIdentities",
    "cookies",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "menus",
    "storage",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "shared/constants.js",
      "shared/match-pattern.js",
      "background/storage-manager.js",
      "background/container-manager.js",
      "background/rule-engine.js",
      "background/tab-interceptor.js",
      "background/context-menu.js",
      "background/page-action-indicator.js",
      "background/background.js"
    ]
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon-48.svg"
  },
  "options_ui": {
    "page": "options/options.html",
    "browser_style": true
  },
  "icons": {
    "48": "icons/icon-48.svg"
  }
}
