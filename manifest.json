{
  "manifest_version": 2,
  "name": "Container Tab Manager",
  "version": "1.0.4",
  "description": "Isolate every new tab in its own container by default, with smart URL-based sharing rules",
  "permissions": [
    "contextualIdentities",
    "cookies",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "menus",
    "storage",
    "idle",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "shared/constants.js",
      "shared/match-pattern.js",
      "background/storage-manager.js",
      "background/container-manager.js",
      "background/rule-engine.js",
      "background/tab-interceptor.js",
      "background/context-menu.js",
      "background/page-action-indicator.js",
      "background/ip-timezone.js",
      "background/background.js"
    ]
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon-48.svg"
  },
  "options_ui": {
    "page": "options/options.html",
    "browser_style": true
  },
  "icons": {
    "48": "icons/icon-48.svg"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content/fingerprint-noise.js"],
    "run_at": "document_start",
    "all_frames": true
  }, {
    "matches": ["<all_urls>"],
    "js": ["content/timezone-spoof.js"],
    "run_at": "document_start",
    "all_frames": true
  }],
  "browser_specific_settings": {
    "gecko": {
      "id": "container-tab-manager@alexeytuboltsev",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
